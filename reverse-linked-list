class Solution {
    public ListNode reverseList(ListNode head) {
        ArrayList<Integer> arr=new ArrayList<>();
        ListNode temp=head;
        while(temp!=null){

            arr.add(temp.val);
            temp=temp.next;
        }
        Collections.reverse(arr);
        temp=head;
        for(int i=0;i<arr.size();i++){
            temp.val=arr.get(i);
            temp=temp.next;

        }
        return head;

        
    }
}
